# Tiptap publishes its packages as a suite where every @tiptap/* package pins an
# exact peer on @tiptap/core. Our pinned set mixes 3.22.4 and 3.22.5 across the
# extensions, which npm v7+'s strict peer resolver rejects with ERESOLVE during a
# clean install (e.g. on Vercel). This matches the lenient (npm v6-style)
# resolution the project has always installed with locally, so CI/Vercel installs
# succeed without --legacy-peer-deps on the command line.
legacy-peer-deps=true
